# Environment configuration
NODE_ENV=production
PORT=5000

# MongoDB Connection String (Atlas recommended)
MONGO_URI=mongodb+srv://...

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...

# Nodemailer SMTP Configuration
# For production, use a reliable service like SendGrid, Mailgun, or Gmail App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=...
SMTP_PASS=...
FROM_NAME=RentRide
FROM_EMAIL=...

# Frontend URL (Important for CORS and password reset links)
# Example: https://rentride.vercel.app
CLIENT_URL=http://localhost:5173
